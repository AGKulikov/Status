<manifest xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission
        android:name="android.permission.ACCESS_BACKGROUND_LOCATION"
        tools:ignore="BackgroundLocationPolicy" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <!-- Legacy Bluetooth permissions (granted at install time on targetSdk 28). They are
         sufficient on Android 9-12 for the calls we make: reading adapter state, observing
         ACL connect/disconnect broadcasts, and querying the connected device count. The new
         runtime permissions BLUETOOTH_CONNECT / BLUETOOTH_SCAN (API 31+) only kick in for
         apps that target API 31+. -->
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- Required on Android 11+ so PackageManager.queryIntentActivities can list launcher/home
         apps for the "Hide widget in apps" picker. Without these, the picker would show only
         our own app. -->
    <queries>
        <package android:name="ru.yandex.yandexmaps" />
        <package android:name="ru.yandex.yandexnavi" />
        <package android:name="com.yandex.yango" />
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.HOME" />
        </intent>
    </queries>

    <application
        android:name=".StatusWidgetApplication"
        android:allowBackup="true"
        android:usesCleartextTraffic="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.StatusWidget">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".LauncherActivity"
            android:excludeFromRecents="true"
            android:exported="true"
            android:launchMode="singleTask"
            android:resizeableActivity="false"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.StatusWidget.Launcher">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <activity
            android:name=".LauncherSettingsActivity"
            android:exported="false"
            android:screenOrientation="landscape" />

        <activity
            android:name=".LauncherShortcutSettingsActivity"
            android:exported="false"
            android:screenOrientation="landscape" />

        <activity
            android:name=".FavoriteAppsSettingsActivity"
            android:exported="false"
            android:screenOrientation="landscape" />

        <activity
            android:name=".ClimatePanelSettingsActivity"
            android:exported="false"
            android:screenOrientation="landscape" />

        <activity
            android:name=".VehicleInfoPanelSettingsActivity"
            android:exported="false"
            android:screenOrientation="landscape" />

        <activity
            android:name=".MediaPanelSettingsActivity"
            android:exported="false"
            android:screenOrientation="landscape" />

        <activity
            android:name=".FavoriteRoutesSettingsActivity"
            android:exported="false"
            android:screenOrientation="landscape" />

        <activity
            android:name=".PanelElementSettingsActivity"
            android:exported="false"
            android:screenOrientation="landscape" />

        <activity
            android:name=".AppSelectionActivity"
            android:exported="false" />

        <activity
            android:name=".AboutActivity"
            android:exported="false" />

        <activity
            android:name=".AutomationSettingsActivity"
            android:exported="false" />

        <activity
            android:name=".MqttSettingsActivity"
            android:exported="false" />

        <activity
            android:name=".VisualBrickEditorActivity"
            android:exported="false" />

        <activity
            android:name=".PopupSettingsActivity"
            android:exported="false" />

        <activity
            android:name=".SprutHubSettingsActivity"
            android:exported="false" />

        <activity
            android:name=".HomeAssistantSettingsActivity"
            android:exported="false" />

        <activity
            android:name=".ScenarioSettingsActivity"
            android:exported="false" />

        <activity
            android:name=".IntentScenarioSettingsActivity"
            android:exported="false" />

        <activity
            android:name=".PresetsActivity"
            android:exported="false" />

        <service
            android:name=".WidgetService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="location" />

        <service
            android:name=".climate.ClimatePanelService"
            android:directBootAware="true"
            android:enabled="true"
            android:exported="false"
            android:stopWithTask="false" />

        <service
            android:name=".MediaNotificationListener"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- mHUD/mSaver-compatible players publish rich media metadata here. Keeping this
             receiver manifest-declared means the latest state is cached even when HOME and the
             settings UI are not open. The controller also listens dynamically while HOME is
             visible for head units that restrict implicit manifest broadcasts. -->
        <receiver
            android:name=".launcher.MediaInfoBroadcastReceiver"
            android:directBootAware="true"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="plus.monjaro.MEDIA_INFO_UPDATE" />
                <action android:name="plus.monjaro.MEDIA_INFO_CLEAR" />
                <action android:name="debug.monjaro.MEDIA_INFO_UPDATE" />
                <action android:name="debug.monjaro.MEDIA_INFO_CLEAR" />
            </intent-filter>
        </receiver>

        <!-- Accessibility service for per-display foreground app tracking. Required only on
             multi-display head units (Geely Monjaro et al.); on single-display devices the
             original UsageStatsManager-based detection is sufficient and the user can leave
             this off. -->
        <service
            android:name=".WidgetAccessibilityService"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/widget_accessibility_service" />
        </service>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <receiver
            android:name=".BootReceiver"
            android:directBootAware="true"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.RECEIVE_BOOT_COMPLETED">

            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="android.intent.action.USER_UNLOCKED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- Explicit broadcasts sent by Home Assistant Companion. MQTT is the primary transport,
             but this stable action remains supported for compatibility and manual testing. -->
        <receiver
            android:name=".automation.HaUpdateReceiver"
            android:directBootAware="true"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="ru.natro.statuswidget.HA_UPDATE" />
                <action android:name="ru.natro.statuswidget.HA_CLEAR" />
                <action android:name="ru.natro.statuswidget.HA_VISIBILITY" />
                <action android:name="ru.natro.statuswidget.HA_BUILTIN_VISIBILITY" />
                <action android:name="ru.natro.statuswidget.HA_POPUP_UPDATE" />
                <action android:name="ru.natro.statuswidget.HA_POPUP_CLEAR" />
                <action android:name="ru.natro.statuswidget.HA_POPUP_VISIBILITY" />
                <action android:name="ru.natro.statuswidget.HA_SYNC_REQUEST" />
                <action android:name="ru.natro.statuswidget.HA_REFRESH" />
            </intent-filter>
        </receiver>

        <!-- Cold-start endpoint for one-shot scenario commands. The fixed action accepts only a
             saved rule id plus its random token. A sender that needs a configured action while
             the process is stopped must explicitly address this receiver class and know the
             random action suffix. Both paths use the saved allowlist before starting the service. -->
        <receiver
            android:name=".automation.ScenarioTriggerReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="ru.natro.statuswidget.SCENARIO_TRIGGER" />
            </intent-filter>
        </receiver>

        <!-- Route values published by supported Yandex Navigator/Maps builds and MConfig. -->
        <receiver
            android:name=".launcher.YandexNavigationReceiver"
            android:directBootAware="true"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="com.yandex.ARRIVAL" />
                <action android:name="com.yandex.TIME" />
                <action android:name="com.yandex.DISTANCE" />
                <action android:name="plus.monjaro.NAVIGATION_UPDATE" />
                <action android:name="plus.monjaro.NAVIGATION_ENDED" />
                <action android:name="plus.monjaro.TRAFFIC_LIGHT_UPDATE" />
                <action android:name="plus.monjaro.LANE_SIGN_DIST" />
                <action android:name="com.yandex.LANE_SIGN" />
                <action android:name="com.yandex.LANE_DIST" />
                <action android:name="com.yandex.LANES_BITMAP" />
                <action android:name="com.yandex.LANES_BITMAP_CLEAR" />
                <action android:name="com.yandex.JAM_IMAGE" />
                <action android:name="com.yandex.JAM_IMAGE_CLEAR" />
                <action android:name="plus.monjaro.RAINBOW_IMAGE" />
                <action android:name="plus.monjaro.RAINBOW_IMAGE_CLEAR" />
                <action android:name="debug.monjaro.NAVIGATION_UPDATE" />
                <action android:name="debug.monjaro.NAVIGATION_ENDED" />
                <action android:name="debug.monjaro.TRAFFIC_LIGHT_UPDATE" />
                <action android:name="debug.monjaro.RAINBOW_IMAGE" />
                <action android:name="debug.monjaro.RAINBOW_IMAGE_CLEAR" />
            </intent-filter>
        </receiver>

        <!-- mHUD/MConfig-compatible Auto Hold state. It must remain manifest-declared so a
             transition received while HOME is closed or the process is dead is not lost. -->
        <receiver
            android:name=".car.AutoHoldStateReceiver"
            android:directBootAware="true"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="plus.monjaro.AUTOHOLD" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
