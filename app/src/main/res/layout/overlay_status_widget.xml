<!--
   Two-level root: outer FrameLayout is attached to WindowManager so we can resize the
   *window* (pre-expand to screen width / pin to current width) for the duration of a
   visibility transition without confusing TransitionManager, which animates children
   inside the inner LinearLayout instead.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/overlay_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <dezz.status.widget.BufferingLinearLayout
        android:id="@+id/overlay_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

    <!-- Status-bar mode containers + spacers. Hidden in floating mode; bricks live as direct
         children of the inner container then. WidgetService rearranges things at runtime. -->
    <LinearLayout
        android:id="@+id/startGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone" />

    <View
        android:id="@+id/startCenterSpacer"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_weight="1"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/centerGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone" />

    <View
        android:id="@+id/centerEndSpacer"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_weight="1"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/endGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone" />

    <!-- includeFontPadding=false everywhere: removes the per-TextView reserve under font
         ascenders / descenders that we don't need for the languages/glyphs this widget
         renders. Makes the widget visibly more compact and keeps baselines aligned
         across time / date / media when they share a font size. -->
    <dezz.status.widget.OutlineTextView
        android:id="@+id/timeText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:fontFamily="@font/roboto_condensed_medium"
        android:includeFontPadding="false"
        android:textColor="@color/text_primary"
        android:textSize="100sp"
        tools:text="10:00" />

    <dezz.status.widget.OutlineTextView
        android:id="@+id/dateText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:fontFamily="@font/roboto_condensed_medium"
        android:includeFontPadding="false"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        tools:text=" Tue, 10 Nov " />

    <LinearLayout
        android:id="@+id/mediaContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Source row: play/pause indicator + the app the audio comes from ("▶ Spotify"). The
             indicator is a drawn shape, not a glyph, and takes its size / colour / outline from
             whichever line hosts it. WidgetService re-parents it into the title row when the
             source line is switched off, so the state is never lost. -->
        <LinearLayout
            android:id="@+id/mediaSourceRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <dezz.status.widget.MediaStateIconView
                android:id="@+id/mediaStateIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4sp" />

            <dezz.status.widget.MarqueeOutlineTextView
                android:id="@+id/mediaAppText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/roboto_condensed_medium"
                android:includeFontPadding="false"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                tools:text="Spotify"
                tools:visibility="visible" />
        </LinearLayout>

        <!-- Title row: the (possibly scrolling) track subtitle plus an optional duration text. -->
        <LinearLayout
            android:id="@+id/mediaTitleRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <dezz.status.widget.MarqueeOutlineTextView
                android:id="@+id/mediaTitleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/roboto_condensed_medium"
                android:includeFontPadding="false"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                tools:text="Track — Artist"
                tools:visibility="visible" />

            <dezz.status.widget.OutlineTextView
                android:id="@+id/mediaDurationText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/roboto_condensed_medium"
                android:includeFontPadding="false"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:visibility="gone"
                tools:text=" 4:56" />
        </LinearLayout>

        <dezz.status.widget.MediaProgressBar
            android:id="@+id/mediaProgressBar"
            android:layout_width="match_parent"
            android:layout_height="3sp"
            android:layout_marginTop="2sp"
            android:visibility="gone"
            tools:visibility="visible" />
    </LinearLayout>

    <dezz.status.widget.OutlineImageView
        android:id="@+id/wifiStatusIcon"
        android:layout_width="100sp"
        android:layout_height="100sp"
        android:layout_gravity="center_vertical"
        android:paddingHorizontal="4sp"
        android:src="@drawable/ic_status_wifi_off"
        tools:ignore="ContentDescription" />

    <dezz.status.widget.OutlineImageView
        android:id="@+id/gnssStatusIcon"
        android:layout_width="100sp"
        android:layout_height="100sp"
        android:layout_gravity="center_vertical"
        android:paddingHorizontal="4sp"
        android:src="@drawable/ic_status_gps_off"
        tools:ignore="ContentDescription" />

    <dezz.status.widget.OutlineImageView
        android:id="@+id/bluetoothStatusIcon"
        android:layout_width="100sp"
        android:layout_height="100sp"
        android:layout_gravity="center_vertical"
        android:paddingHorizontal="4sp"
        android:src="@drawable/ic_status_bt_off"
        tools:ignore="ContentDescription" />

    <!-- Car-specific bricks (fed by the flavor's CarIntegration). Direct children of the
         container like every other brick so status-bar mode can re-parent them. -->
    <dezz.status.widget.OutlineTextView
        android:id="@+id/indoorTempText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:fontFamily="@font/roboto_condensed_medium"
        android:includeFontPadding="false"
        android:textColor="@color/text_primary"
        android:textSize="40sp"
        tools:text="21°" />

    <dezz.status.widget.OutlineTextView
        android:id="@+id/outdoorTempText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:fontFamily="@font/roboto_condensed_medium"
        android:includeFontPadding="false"
        android:textColor="@color/text_primary"
        android:textSize="40sp"
        tools:text="8°" />

    <!-- One first-class brick in the global row; its children are rebuilt from the unlimited
         versioned HA configuration collection by WidgetService. -->
    <LinearLayout
        android:id="@+id/homeAssistantContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone"
        tools:visibility="visible" />
    </dezz.status.widget.BufferingLinearLayout>

</FrameLayout>
