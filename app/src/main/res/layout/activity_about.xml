<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/contentLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/backButton"
            style="?attr/materialIconButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:icon="@drawable/ic_arrow_back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="О приложении и настройки"
            android:textAppearance="?attr/textAppearanceHeadlineSmall" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="40dp">

            <TextView
                android:id="@+id/appVersionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Подключения"
                android:textAppearance="?attr/textAppearanceTitleLarge" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Home Assistant" android:textAppearance="?attr/textAppearanceTitleMedium" />
                    <TextView android:id="@+id/haStatusText" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:layout_marginTop="4dp"
                        android:textAppearance="?attr/textAppearanceBodyMedium" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/haSettingsButton"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="8dp" android:text="Настроить подключение" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="MQTT" android:textAppearance="?attr/textAppearanceTitleMedium" />
                    <TextView android:id="@+id/mqttStatusText" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:layout_marginTop="4dp"
                        android:textAppearance="?attr/textAppearanceBodyMedium" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/mqttSettingsButton"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="8dp" android:text="Настроить подключение" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Sprut.hub" android:textAppearance="?attr/textAppearanceTitleMedium" />
                    <TextView android:id="@+id/sprutStatusText" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:layout_marginTop="4dp"
                        android:textAppearance="?attr/textAppearanceBodyMedium" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/sprutSettingsButton"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="8dp" android:text="Настроить подключение и устройства" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Интерфейс и автоматизация"
                android:textAppearance="?attr/textAppearanceTitleLarge" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/mainBricksButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Элементы основной строки" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/popupSettingsButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Плавающий оверлей и его плитки" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/climatePanelSettingsButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Постоянная климатическая панель" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/scenarioSettingsButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Визуальные сценарии" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/intentSettingsButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Команды с кнопок руля" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Данные автомобиля"
                android:textAppearance="?attr/textAppearanceTitleLarge" />

            <TextView
                android:id="@+id/carDiagnosticsStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/car_diagnostics_loading"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textIsSelectable="true" />

            <LinearLayout
                android:id="@+id/carDiagnosticsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
