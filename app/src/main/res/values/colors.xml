<resources>
    <color name="ic_launcher_background">#FFFFFF</color>

    <!-- Overlay widget colors (used by the floating widget itself, not by the settings UI). -->
    <color name="widget_background">#FFFFFF</color>
    <color name="text_primary">#FF000000</color>
    <color name="text_outline">#AAFFFFFF</color>

    <!-- Semantic state colors for status icons (Color and Monocolor styles). -->
    <color name="status_ok">#34A853</color>
    <color name="status_warning">#F9A825</color>
    <color name="status_error">#E53935</color>
    <color name="status_off">#8E8E8E</color>
    <color name="status_bluetooth">#0082FC</color>
    <!-- Fixed dark ink for text badges drawn on a colored pill (DR / anti-spoof). Intentionally
         has no values-night override so it stays dark on amber / red in both themes. -->
    <color name="status_badge_text">#FF000000</color>

    <!-- Apple-inspired semantic tokens used by the settings UI.  They deliberately stay separate
         from launcher/widget colors: changing the HOME background must never repaint settings. -->
    <color name="settings_accent">#007AFF</color>
    <color name="settings_background">#F2F2F7</color>
    <color name="settings_sidebar_background">#E9E9EF</color>
    <color name="settings_group_background">#FFFFFFFF</color>
    <color name="settings_search_background">#E3E3E8</color>
    <color name="settings_separator">#2F3C3C43</color>
    <color name="settings_secondary_text">#FF636366</color>
    <color name="settings_tertiary_text">#4D3C3C43</color>
    <color name="settings_pressed">#1F007AFF</color>
    <color name="settings_destructive">#FF3B30</color>
    <color name="settings_success">#34C759</color>
    <color name="settings_warning">#FF9500</color>
    <color name="settings_purple">#AF52DE</color>
    <color name="settings_indigo">#5856D6</color>
</resources>
